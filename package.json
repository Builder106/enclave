{
  "name": "enclave",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "generate": "tsx scripts/generate.ts",
    "measure": "tsx scripts/measure.ts",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "e2e": "bddgen && playwright test",
    "e2e:report": "playwright show-report",
    "demo": "bddgen --config playwright.demo.config.ts && playwright test --config playwright.demo.config.ts",
    "demo:gif": "sh scripts/make-demo-gif.sh"
  },
  "dependencies": {
    "@ai-sdk/amazon-bedrock": "^3.0.101",
    "@ai-sdk/openai-compatible": "^1.0.39",
    "@base-ui/react": "^1.5.0",
    "@libsql/client": "^0.17.3",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "ai": "^5.0.197",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "lucide-react": "^1.17.0",
    "next": "16.2.9",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "shadcn": "^4.11.0",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "drizzle-kit": "^0.31.10",
    "eslint": "^10",
    "eslint-config-next": "16.2.9",
    "playwright-bdd": "^9.0.0",
    "tailwindcss": "^4",
    "tsx": "^4.22.4",
    "typescript": "^5",
    "vitest": "^3.2.6"
  },
  "packageManager": "pnpm@11.5.2"
}
