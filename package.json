{
  "name": "enclave",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "generate": "tsx scripts/generate.ts",
    "measure": "tsx scripts/measure.ts",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "e2e": "bddgen && playwright test",
    "e2e:report": "playwright show-report",
    "demo": "bddgen --config playwright.demo.config.ts && playwright test --config playwright.demo.config.ts",
    "demo:gif": "sh scripts/make-demo-gif.sh"
  },
  "dependencies": {
    "@ai-sdk/amazon-bedrock": "^5.0.10",
    "@ai-sdk/openai-compatible": "^3.0.5",
    "@base-ui/react": "^1.6.0",
    "@libsql/client": "^0.17.4",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "ai": "^7.0.14",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "lucide-react": "^1.23.0",
    "next": "16.2.10",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "shadcn": "^4.12.0",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4.3.2",
    "@types/node": "^26.1.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "drizzle-kit": "^0.31.10",
    "eslint": "^10.6.0",
    "eslint-config-next": "16.2.10",
    "playwright-bdd": "^9.2.0",
    "tailwindcss": "^4.3.2",
    "tsx": "^4.22.5",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "packageManager": "pnpm@11.9.0"
}
