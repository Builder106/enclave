{
  "name": "enclave",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vinxi dev",
    "build": "vinxi build",
    "start": "vinxi start",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "generate": "tsx scripts/generate.ts",
    "measure": "tsx scripts/measure.ts",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "e2e": "bddgen && playwright test",
    "e2e:report": "playwright show-report",
    "demo": "bddgen --config playwright.demo.config.ts && playwright test --config playwright.demo.config.ts",
    "demo:gif": "sh scripts/make-demo-gif.sh"
  },
  "dependencies": {
    "@ai-sdk/amazon-bedrock": "^5.0.30",
    "@ai-sdk/openai-compatible": "^3.0.14",
    "@ai-sdk/solid": "^0.0.38",
    "@kobalte/core": "^0.13.7",
    "@libsql/client": "^0.17.4",
    "@solidjs/meta": "^0.29.3",
    "@solidjs/router": "^0.16.2",
    "@solidjs/start": "^1.0.0",
    "ai": "^7.0.37",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "lucide-solid": "^1.26.0",
    "solid-js": "^1.8.17",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4.3.3",
    "@types/node": "^26.1.1",
    "drizzle-kit": "^0.31.10",
    "eslint": "^10.7.0",
    "playwright-bdd": "^9.2.0",
    "tailwindcss": "^4.3.3",
    "tsx": "^4.23.1",
    "typescript": "^5.3.3",
    "vinxi": "^0.5.11",
    "vite": "^6.0.0",
    "vitest": "^4.1.10",
    "@vitest/coverage-v8": "^4.1.10"
  },
  "packageManager": "pnpm@11.9.0"
}
